<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Account</title>
    <link rel="stylesheet" href="./css/style.css" />
  </head>

  <body>
    <nav>
      <a href="/">Home</a>
      <a href="#" onclick="logout()">Logout</a>
    </nav>

    <h1>Welcome <%= user.username %></h1>
    <p>Your email is <%= user.email %>.</p>
    <p>Your role is <%= user.role %>.</p>
    <p>Your roleId is <%= user.roleId %>.</p>

    <div>
      <h2>Change Email</h2>
      <form>
        <input
          type="email"
          name="newEmail"
          id="newEmail"
          placeholder="New email"
          required
        />
        <button type="button" onclick="handleEmailUpdate(event)">
          Change Email
        </button>
      </form>
    </div>
    <script defer src="./js/script.js"></script>
    <script>
      async function logout() {
        await fetch("/logout", {
          method: "POST",
        });
        window.location.href = "/"; // Redirect to login page
      }
      // checkLogin(); // Ensure the user is logged in before loading the page
    </script>
  </body>
</html>
