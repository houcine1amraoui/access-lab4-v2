<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home</title>
    <link rel="stylesheet" href="./css/style.css" />
  </head>

  <body>
    <nav id="navbar">
      <a href="/">Home</a>
      <a href="/account">My Account</a>
    </nav>

    <div class="main">
      <h1>Task 4: User role can be modified in user profile</h1>
      <p>
        This application has an admin panel at <strong>/admin</strong>. It's
        only accessible to logged-in users with a roleId of 2.
      </p>
      <p>
        Solve the lab by accessing the admin panel and using it to delete one of
        the users.
      </p>
      <p>
        You can log in to your own account using the following credentials:
        <strong><%= users[1].username %>:<%= users[1].password %></strong>
      </p>
    </div>
    <br />

    <script defer src="./js/script.js"></script>
  </body>
  <script>
    async function fetchUserRole() {
      try {
        const response = await fetch("/user-role"); // Backend should return { roleId: 2 } if admin
        const data = await response.json();

        if (data.roleId === 2) {
          const navbar = document.getElementById("navbar");
          const adminLink = document.createElement("a");
          adminLink.href = "/admin";
          adminLink.textContent = "Admin Panel";
          navbar.appendChild(adminLink);
        }
      } catch (error) {
        console.error("Error fetching user role:", error);
      }
    }

    fetchUserRole();
  </script>
</html>
